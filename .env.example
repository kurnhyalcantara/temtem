# Environment overrides for config.yaml.
# Convention: TEMTEM_ prefix, double underscore separates nesting levels,
# single underscores are kept within a key name.
#   TEMTEM_POSTGRES__MAX_CONNS  ->  postgres.max_conns
# Precedence: defaults < config/config.yaml < environment variables.

TEMTEM_APP__ENV=development

TEMTEM_POSTGRES__HOST=localhost
TEMTEM_POSTGRES__PORT=5432
TEMTEM_POSTGRES__USER=temtem
TEMTEM_POSTGRES__PASSWORD=temtem
TEMTEM_POSTGRES__DATABASE=temtem

TEMTEM_REDIS__ADDR=localhost:6379
TEMTEM_REDIS__PASSWORD=

# Never use this value outside local development.
TEMTEM_JWT__SECRET=local-development-secret-change-me
