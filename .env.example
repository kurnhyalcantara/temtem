# Local dev env vars — copy to .env (gitignored) and fill in real values.
# This is the naming convention for all TEMTEM_ env vars: TEMTEM_ prefix,
# "__" separates nesting levels (TEMTEM_POSTGRES__HOST -> postgres.host).
# Anything left unset here falls back to the defaults in config/config.go.
# The server refuses to start without TEMTEM_JWT__SECRET.

# --- postgres (no password default — must be set explicitly) ---
TEMTEM_POSTGRES__HOST=localhost
TEMTEM_POSTGRES__PORT=5432
TEMTEM_POSTGRES__USER=temtem
TEMTEM_POSTGRES__PASSWORD=temtem
TEMTEM_POSTGRES__DATABASE=temtem
TEMTEM_POSTGRES__SSL_MODE=disable

# --- redis ---
TEMTEM_REDIS__ADDR=localhost:6379

# --- jwt (required) ---
TEMTEM_JWT__SECRET=local-development-secret-change-me

# --- log ---
TEMTEM_LOG__LEVEL=debug
TEMTEM_LOG__FORMAT=text

# --- migrations (make migrate-up/migrate-down read these too) ---
# Set this instead if your password has reserved URL characters (e.g. '@' -> '%40').
# TEMTEM_MIGRATE_DATABASE_URL=postgres://user:pass@localhost:5432/temtem?sslmode=disable
